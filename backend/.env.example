# ══════════════════════════════════════════════════════════
# NexusOps Backend — Production Environment Variables
# ══════════════════════════════════════════════════════════
# Copy to .env for local dev, or set as env vars in Railway

# ── Core ──
# Railway auto-provides DATABASE_URL when you add a PostgreSQL plugin.
# For local dev, use SQLite:
#   DATABASE_URL=sqlite+aiosqlite:///./nexusop_dev.db
# For production (auto-set by Railway Postgres plugin):
#   DATABASE_URL=postgresql://user:pass@host:port/dbname
DATABASE_URL=sqlite+aiosqlite:///./nexusop_dev.db

# Railway auto-provides REDIS_URL when you add a Redis plugin.
REDIS_URL=redis://localhost:6379/0

# IMPORTANT: Generate a strong secret for production!
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production

# Comma-separated list of allowed frontend origins
# Update with your actual Vercel deployment URL
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Set to false in production
DEBUG=false

# Your Vercel frontend URL (used for OAuth redirects, emails, etc.)
FRONTEND_URL=https://your-app.vercel.app

# ── AI: Groq (REQUIRED for AutoFix) ──
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── AI: OpenAI — embeddings + Whisper STT ──
OPENAI_API_KEY=

# ── GitHub OAuth + Code Fetch ──
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=

# ── Sentry Webhook ──
SENTRY_WEBHOOK_SECRET=

# ── Jira ──
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=
JIRA_USER_EMAIL=
JIRA_PROJECT_KEY=NEX

# ── Deploy Platforms (auto-revert) ──
VERCEL_TOKEN=
RAILWAY_TOKEN=

# ── Cloudflare R2 Storage ──
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=nexusops
CLOUDFLARE_R2_ENDPOINT=

# ── Firebase ──
FIREBASE_WEB_API_KEY=
